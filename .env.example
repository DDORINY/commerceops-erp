# CommerceOps ERP shared environment example
# Copy values into local secret files or platform environment variables.

# Backend profile
SPRING_PROFILES_ACTIVE=local

# Backend database
DB_URL=jdbc:mysql://localhost:3308/commerceops?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
DB_USERNAME=commerce
DB_PASSWORD=change-me

# Backend auth
JWT_SECRET=replace-with-base64-secret-at-least-256-bit
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=1209600000

# Backend CORS and media
COMMERCEOPS_CORS_ALLOWED_ORIGINS=http://localhost:3000
COMMERCEOPS_MEDIA_UPLOAD_DIR=uploads
COMMERCEOPS_MEDIA_PUBLIC_BASE_URL=http://localhost:8080

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
